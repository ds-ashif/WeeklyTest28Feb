@model dynamic

@{
    ViewData["Title"] = "Results";
}

<h2 class="mb-3">Search Results</h2>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">
        No results found.
    </div>
}
else
{
    <!-- ========================= -->
    <!-- FLIGHT ONLY RESULTS -->
    <!-- ========================= -->
    @if (Model[0] is FlightSearchEngine.Models.ViewModels.FlightResult)
    {
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>FlightId</th>
                    <th>Flight Name</th>
                    <th>Flight Type</th>
                    <th>Source</th>
                    <th>Destination</th>
                    <th>Total Cost</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FlightId</td>
                        <td>@item.FlightName</td>
                        <td>@item.FlightType</td>
                        <td>@item.Source</td>
                        <td>@item.Destination</td>
                        <td>₹ @item.TotalCost</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <!-- ========================= -->
    <!-- FLIGHT + HOTEL RESULTS -->
    <!-- ========================= -->
    else if (Model[0] is FlightSearchEngine.Models.ViewModels.FlightHotelResult)
    {
        <table class="table table-bordered table-striped">
            <thead class="table-success">
                <tr>
                    <th>FlightId</th>
                    <th>Flight Name</th>
                    <th>Source</th>
                    <th>Destination</th>
                    <th>Hotel Name</th>
                    <th>Total Cost</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FlightId</td>
                        <td>@item.FlightName</td>
                        <td>@item.Source</td>
                        <td>@item.Destination</td>
                        <td>@item.HotelName</td>
                        <td>₹ @item.TotalCost</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

<br />

<a asp-action="Index" class="btn btn-secondary">
    Back to Search
</a>